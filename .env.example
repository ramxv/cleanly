# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=cleanly
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cleanly_db
POSTGRES_PORT=5432

# ─── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cleanly:changeme@db:5432/cleanly_db
NODE_ENV=development
BACKEND_PORT=3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
FRONTEND_PORT=80

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AWS S3 (for document uploads) ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ─── PagueloFácil (payment gateway) ──────────────────────────────────────────
PAGUELOFACIL_API_KEY=
PAGUELOFACIL_BASE_URL=

# ─── Email (Resend / Mailgun) ─────────────────────────────────────────────────
MAIL_FROM=noreply@cleanly.pa
RESEND_API_KEY=

# ─── Business Rules ───────────────────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.15
