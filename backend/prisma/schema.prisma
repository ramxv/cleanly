// Cleanly — Plataforma de Servicios de Limpieza Doméstica

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMERACIONES
// ─────────────────────────────────────────────────────────────────────────────

enum Rol {
  CLIENTE
  TRABAJADOR
  ADMIN
}

enum EstadoVerificacion {
  PENDIENTE
  APROBADO
  RECHAZADO
  SUSPENDIDO
}

enum TipoServicio {
  ESTANDAR
  PROFUNDA
  POST_OBRA
}

enum EstadoReserva {
  PENDIENTE_PAGO
  CONFIRMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
  DISPUTADA
}

enum EstadoPago {
  PENDIENTE
  RETENIDO
  LIBERADO
  REEMBOLSADO
  FALLIDO
}

enum ActorCancelacion {
  CLIENTE
  TRABAJADOR
  ADMIN
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

// ─────────────────────────────────────────────────────────────────────────────
// USUARIOS Y AUTENTICACIÓN
// ─────────────────────────────────────────────────────────────────────────────

model Usuario {
  id             String   @id @default(cuid())
  correo         String   @unique
  contrasenaHash String
  rol            Rol
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  perfilCliente    PerfilCliente?
  perfilTrabajador PerfilTrabajador?
  sesiones         Sesion[]

  @@index([correo])
  @@map("usuarios")
}

model Sesion {
  id        String   @id @default(cuid())
  usuarioId String
  token     String   @unique
  expiraEn  DateTime
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([token])
  @@map("sesiones")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERFIL DE CLIENTE
// ─────────────────────────────────────────────────────────────────────────────

model PerfilCliente {
  id        String  @id @default(cuid())
  usuarioId String  @unique
  nombre    String
  telefono  String?
  fotoUrl   String?

  contadorLealtad Int @default(0)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuario          Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  direcciones      Direccion[]
  solicitudes      SolicitudServicio[]
  reservas         Reserva[]
  resenasEmitidas  Resena[]            @relation("ResenasEmitidas")
  resenasRecibidas Resena[]            @relation("ResenasRecibidas")

  @@map("perfiles_clientes")
}

model Direccion {
  id                String  @id @default(cuid())
  perfilClienteId   String
  etiqueta          String
  direccionCompleta String
  barrio            String
  distrito          String
  provincia         String
  esPredeterminada  Boolean @default(false)

  cliente  PerfilCliente @relation(fields: [perfilClienteId], references: [id], onDelete: Cascade)
  reservas Reserva[]

  @@index([perfilClienteId])
  @@map("direcciones")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERFIL DE TRABAJADOR
// ─────────────────────────────────────────────────────────────────────────────

model PerfilTrabajador {
  id        String  @id @default(cuid())
  usuarioId String  @unique
  nombre    String
  telefono  String?
  fotoUrl   String?
  biografia String?

  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  verificadoEn       DateTime?
  motivoRechazo      String?

  calificacionPromedio Float @default(0)
  totalResenas         Int   @default(0)

  esPremium       Boolean   @default(false)
  premiumExpiraEn DateTime?

  tarifaPorHora Float

  tiposServicio TipoServicio[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuario          Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  documentos       DocumentoTrabajador[]
  disponibilidad   Disponibilidad[]
  zonasServicio    ZonaServicio[]
  reservas         Reserva[]
  resenasEmitidas  Resena[]              @relation("ResenasEmitidas")
  resenasRecibidas Resena[]              @relation("ResenasRecibidas")
  historialPremium SuscripcionPremium[]

  @@map("perfiles_trabajadores")
}

model DocumentoTrabajador {
  id                 String    @id @default(cuid())
  perfilTrabajadorId String
  tipo               String
  archivoUrl         String
  fechaEmision       DateTime?
  subidoEn           DateTime  @default(now())
  revisadoEn         DateTime?
  aprobado           Boolean?

  trabajador PerfilTrabajador @relation(fields: [perfilTrabajadorId], references: [id], onDelete: Cascade)

  @@index([perfilTrabajadorId])
  @@map("documentos_trabajadores")
}

model Disponibilidad {
  id                 String    @id @default(cuid())
  perfilTrabajadorId String
  diaSemana          DiaSemana
  horaInicio         String
  horaFin            String

  trabajador PerfilTrabajador @relation(fields: [perfilTrabajadorId], references: [id], onDelete: Cascade)

  @@unique([perfilTrabajadorId, diaSemana, horaInicio])
  @@index([perfilTrabajadorId])
  @@map("disponibilidades")
}

model ZonaServicio {
  id                 String  @id @default(cuid())
  perfilTrabajadorId String
  provincia          String
  distrito           String
  barrio             String?

  trabajador PerfilTrabajador @relation(fields: [perfilTrabajadorId], references: [id], onDelete: Cascade)

  @@index([perfilTrabajadorId])
  @@map("zonas_servicio")
}

// ─────────────────────────────────────────────────────────────────────────────
// SOLICITUDES Y RESERVAS
// ─────────────────────────────────────────────────────────────────────────────

model SolicitudServicio {
  id              String       @id @default(cuid())
  perfilClienteId String
  tipoServicio    TipoServicio
  tamanoM2        Float
  cantidadHabDir  Int
  cantidadBanos   Int
  notas           String?
  fechaHora       DateTime
  barrio          String
  distrito        String
  provincia       String
  presupuestoMax  Float?

  creadoEn DateTime @default(now())

  cliente PerfilCliente @relation(fields: [perfilClienteId], references: [id])
  reserva Reserva?

  @@index([perfilClienteId])
  @@index([fechaHora])
  @@map("solicitudes_servicio")
}

model Reserva {
  id                 String        @id @default(cuid())
  solicitudId        String        @unique
  perfilClienteId    String
  perfilTrabajadorId String
  direccionId        String
  estado             EstadoReserva @default(PENDIENTE_PAGO)

  fechaHora        DateTime
  duracionEstimada Int
  precioTotal      Float

  confirmadaEn DateTime?
  iniciadaEn   DateTime?
  completadaEn DateTime?
  canceladaEn  DateTime?

  canceladoPor      ActorCancelacion?
  motivoCancelacion String?
  montoPenalidad    Float?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  solicitud  SolicitudServicio @relation(fields: [solicitudId], references: [id])
  cliente    PerfilCliente     @relation(fields: [perfilClienteId], references: [id])
  trabajador PerfilTrabajador  @relation(fields: [perfilTrabajadorId], references: [id])
  direccion  Direccion         @relation(fields: [direccionId], references: [id])
  pago       Pago?
  resenas    Resena[]
  disputa    Disputa?

  @@index([perfilClienteId])
  @@index([perfilTrabajadorId])
  @@index([estado])
  @@index([fechaHora])
  @@map("reservas")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGOS
// ─────────────────────────────────────────────────────────────────────────────

model Pago {
  id        String     @id @default(cuid())
  reservaId String     @unique
  estado    EstadoPago @default(PENDIENTE)

  monto         Float
  tasaComision  Float
  montoComision Float
  montoNeto     Float

  referenciaPassarela String?
  claveIdempotencia   String  @unique

  retenidoEn      DateTime?
  liberadoEn      DateTime?
  reembolsadoEn   DateTime?
  motivoReembolso String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  reserva Reserva @relation(fields: [reservaId], references: [id])

  @@index([estado])
  @@index([claveIdempotencia])
  @@map("pagos")
}

// ─────────────────────────────────────────────────────────────────────────────
// CALIFICACIONES Y RESEÑAS
// ─────────────────────────────────────────────────────────────────────────────

model Resena {
  id        String @id @default(cuid())
  reservaId String

  desdeclienteId    String?
  desdeTrabajadorId String?

  paraClienteId    String?
  paraTrabajadorId String?

  estrellas  Int
  comentario String?

  activa           Boolean   @default(true)
  moderadaEn       DateTime?
  motivoModeracion String?

  creadoEn DateTime @default(now())

  reserva         Reserva           @relation(fields: [reservaId], references: [id])
  desdeCliente    PerfilCliente?    @relation("ResenasEmitidas", fields: [desdeclienteId], references: [id])
  paraCliente     PerfilCliente?    @relation("ResenasRecibidas", fields: [paraClienteId], references: [id])
  desdeTrabajador PerfilTrabajador? @relation("ResenasEmitidas", fields: [desdeTrabajadorId], references: [id])
  paraTrabajador  PerfilTrabajador? @relation("ResenasRecibidas", fields: [paraTrabajadorId], references: [id])

  @@index([reservaId])
  @@index([paraTrabajadorId])
  @@map("resenas")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLAN PREMIUM
// ─────────────────────────────────────────────────────────────────────────────

model SuscripcionPremium {
  id                 String  @id @default(cuid())
  perfilTrabajadorId String

  inicioEn       DateTime
  expiraEn       DateTime
  activa         Boolean  @default(true)
  referenciaPago String?

  trabajador PerfilTrabajador @relation(fields: [perfilTrabajadorId], references: [id])

  @@index([perfilTrabajadorId])
  @@map("suscripciones_premium")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISPUTAS
// ─────────────────────────────────────────────────────────────────────────────

model Disputa {
  id          String    @id @default(cuid())
  reservaId   String    @unique
  abiertaPor  Rol
  motivo      String
  resolucion  String?
  resueltaEn  DateTime?
  resueltaPor String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  reserva Reserva @relation(fields: [reservaId], references: [id])

  @@map("disputas")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURACIÓN DE LA PLATAFORMA
// ─────────────────────────────────────────────────────────────────────────────

model ConfiguracionPlataforma {
  id            String   @id @default(cuid())
  clave         String   @unique
  valor         String
  descripcion   String?
  actualizadoEn DateTime @updatedAt

  @@map("configuracion_plataforma")
}
